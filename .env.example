# ============================================================
# Configuration Salesforce — à remplir par tes collègues
# une fois la Connected App créée
# ============================================================

# URL de l'instance Salesforce (Production ou Sandbox)
VITE_SF_INSTANCE_URL=https://your-instance.my.salesforce.com

# Access Token OAuth (récupéré via le flow OAuth de la Connected App)
# Pour le POC, vous pouvez utiliser un token statique en attendant
# le flow OAuth complet
VITE_SF_ACCESS_TOKEN=

# Client ID de la Connected App (pour le flow OAuth côté client)
VITE_SF_CLIENT_ID=

# Domaine OAuth (login.salesforce.com pour prod, test.salesforce.com pour sandbox)
VITE_SF_LOGIN_URL=https://login.salesforce.com

# ============================================================
# Pour basculer du mode MOCK au mode RÉEL :
# ouvrir src/services/salesforceApi.js et passer USE_MOCK = false
# ============================================================
